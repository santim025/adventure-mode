# Copia este archivo como .env.local y pega aquí las llaves que te da
# Firebase en Project Settings -> General -> Your apps -> SDK setup and config.
# Reinicia `npm run dev` después de guardar.
#
# NOTA: Estas variables quedan expuestas en el cliente (es normal con Firebase Web).
# La seguridad la dan las Firestore Rules, NO las keys.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
